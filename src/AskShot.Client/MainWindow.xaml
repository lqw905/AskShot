<Window x:Class="AskShot.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AskShot 控制台" Height="450" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <TabControl Margin="10">
        <!-- LLM Tab -->
        <TabItem Header="LLM 配置">
            <StackPanel Margin="15" VerticalAlignment="Top">
                <TextBlock Text="API 地址" Margin="0,10,0,2"/>
                <TextBox x:Name="TxtEndpoint" Text=""/>

                <TextBlock Text="API Key" Margin="0,10,0,2"/>
                <TextBox x:Name="TxtApiKey" Text=""/>

                <TextBlock Text="模型名称" Margin="0,10,0,2"/>
                <TextBox x:Name="TxtModel" Text="qwen2.5-vl-3b-instruct"/>

                <TextBlock Text="Temperature" Margin="0,10,0,2"/>
                <Slider x:Name="SldTemperature" Minimum="0" Maximum="2"
                        Value="0.7" TickFrequency="0.1" IsSnapToTickEnabled="True"
                        ValueChanged="SldTemperature_Changed"/>
                <TextBlock x:Name="LblTemperature" Text="0.7" HorizontalAlignment="Right"/>

                <TextBlock Text="Max Tokens" Margin="0,10,0,2"/>
                <TextBox x:Name="TxtMaxTokens" Text="2048"/>

                <Button Content="测试连接" Margin="0,20,0,0" Width="100"
                        Click="TestConnection_Click"/>
                <TextBlock x:Name="LblConnectionStatus" Margin="0,5,0,0"
                           Foreground="Gray" Text=""/>
            </StackPanel>
        </TabItem>

        <!-- 截图保存 Tab -->
        <TabItem Header="截图保存">
            <StackPanel Margin="15" VerticalAlignment="Top">
                <CheckBox x:Name="ChkSaveScreenshots" Content="保存截图原图"
                          Margin="0,10,0,5" Checked="SaveConfig"
                          Unchecked="SaveConfig"/>

                <TextBlock Text="截图保存路径" Margin="0,10,0,2"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtScreenshotPath" Grid.Column="0"
                             IsEnabled="False"/>
                    <Button Content="📁" Grid.Column="1" Width="40"
                            Click="BrowseScreenshotPath_Click"/>
                </Grid>

                <TextBlock Text="历史记录保留天数" Margin="0,20,0,2"/>
                <TextBox x:Name="TxtRetentionDays" Text="30" Width="80"/>

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <Button Content="清空历史记录" Width="120" Click="ClearHistory_Click"/>
                    <Button Content="打开数据目录" Width="140" Margin="10,0,0,0"
                            Click="OpenDataDir_Click"/>
                </StackPanel>
            </StackPanel>
        </TabItem>

        <!-- 服务状态 Tab -->
        <TabItem Header="服务状态">
            <StackPanel Margin="15" VerticalAlignment="Top">
                <TextBlock x:Name="LblServiceStatus" Text="Python 服务: 检测中..."
                           FontWeight="Bold" Margin="0,10,0,5"/>
                <Button Content="重启服务" Width="100" Margin="0,20,0,0"
                        Click="RestartService_Click"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
