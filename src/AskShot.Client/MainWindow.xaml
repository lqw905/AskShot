<Window x:Class="AskShot.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AskShot"
        Height="600" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="{DynamicResource RadiusLg}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.12" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Title Bar ──────────────────────────────────── -->
            <Grid Grid.Row="0" Margin="8,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="AskShot"
                           FontFamily="{DynamicResource SerifFont}"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource HeavyForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnMinimize" Content="—"
                            Style="{StaticResource GhostButton}"
                            Width="36" Height="28" FontSize="16"
                            Click="Minimize_Click"/>
                    <Button x:Name="BtnClose" Content="×"
                            Style="{StaticResource GhostButton}"
                            Width="36" Height="28" FontSize="16"
                            Margin="4,0,0,0"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- ── Toast Notification ───────────────────────── -->
            <Border x:Name="ToastBar"
                    Grid.Row="0" Grid.RowSpan="2"
                    VerticalAlignment="Top" HorizontalAlignment="Center"
                    Margin="0,44,0,0"
                    Background="{DynamicResource ForegroundBrush}"
                    CornerRadius="8" Padding="14,8"
                    Visibility="Collapsed" Panel.ZIndex="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <TextBlock x:Name="ToastText" Foreground="#FAFAF5" FontSize="13"
                           FontFamily="{DynamicResource SansFont}"/>
            </Border>

            <!-- ── Content Area ──────────────────────────────── -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid Margin="10">
                    <TabControl Margin="0">
                        <!-- ── General Tab ────────────────────── -->
                        <TabItem Header="通用">
                            <Border Style="{StaticResource CardBorder}"
                                    Margin="0,12,0,0">
                                <StackPanel VerticalAlignment="Top">
                                    <TextBlock Text="截图快捷键" Margin="0,8,0,4"
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               FontWeight="SemiBold"/>
                                    <TextBox x:Name="TxtHotkey" Text="Ctrl+Shift+A"/>
                                    <TextBlock Text="示例：Ctrl+Shift+A、Alt+Shift+Q、Win+Shift+S"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               FontSize="12" Margin="0,4,0,0"/>
                                    <Button Content="保存设置"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="0,20,0,0" Width="120"
                                            Click="SaveConfig_Click"/>
                                </StackPanel>
                            </Border>
                        </TabItem>

                        <!-- ── LLM Config Tab ────────────────── -->
                        <TabItem Header="LLM 配置">
                            <Border Style="{StaticResource CardBorder}"
                                    Margin="0,12,0,0">
                                <StackPanel VerticalAlignment="Top">
                                    <TextBlock Text="API 地址" Margin="0,8,0,4"
                                               FontWeight="SemiBold"/>
                                    <TextBox x:Name="TxtEndpoint" Text=""/>

                                    <TextBlock Text="API Key" Margin="0,14,0,4"
                                               FontWeight="SemiBold"/>
                                    <TextBox x:Name="TxtApiKey" Text=""/>

                                    <TextBlock Text="模型名称" Margin="0,14,0,4"
                                               FontWeight="SemiBold"/>
                                    <TextBox x:Name="TxtModel" Text="qwen2.5-vl-3b-instruct"/>

                                    <TextBlock Text="Temperature" Margin="0,14,0,4"
                                               FontWeight="SemiBold"/>
                                    <Slider x:Name="SldTemperature" Minimum="0" Maximum="2"
                                            Value="0.7" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                            ValueChanged="SldTemperature_Changed"/>
                                    <TextBlock x:Name="LblTemperature" Text="0.7"
                                               HorizontalAlignment="Right" Margin="0,-22,4,0"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               FontSize="12"/>

                                    <TextBlock Text="Max Tokens" Margin="0,14,0,4"
                                               FontWeight="SemiBold"/>
                                    <TextBox x:Name="TxtMaxTokens" Text="2048" Width="120"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
                                        <Button Content="测试连接" Width="120"
                                                Style="{StaticResource PrimaryButton}"
                                                Click="TestConnection_Click"/>
                                        <Button Content="保存设置" Width="120"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="8,0,0,0"
                                                Click="SaveConfig_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </TabItem>

                        <!-- ── Screenshot Tab ─────────────────── -->
                        <TabItem Header="截图保存">
                            <Border Style="{StaticResource CardBorder}"
                                    Margin="0,12,0,0">
                                <StackPanel VerticalAlignment="Top">
                                    <CheckBox x:Name="ChkSaveScreenshots" Content="保存截图原图"
                                              Margin="0,8,0,4" Checked="SaveConfig"
                                              Unchecked="SaveConfig"/>

                                    <TextBlock Text="截图保存路径" Margin="0,12,0,4"
                                               FontWeight="SemiBold"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtScreenshotPath" Grid.Column="0"
                                                 IsEnabled="False"/>
                                        <Button Grid.Column="1" Content="📁"
                                                Style="{StaticResource SecondaryButton}"
                                                Width="44" Margin="8,0,0,0"
                                                Click="BrowseScreenshotPath_Click"/>
                                    </Grid>

                                    <TextBlock Text="历史记录保留天数" Margin="0,16,0,4"
                                               FontWeight="SemiBold"/>
                                    <TextBox x:Name="TxtRetentionDays" Text="30" Width="80"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,20,0,4">
                                        <Button Content="清空历史记录" Width="130"
                                                Style="{StaticResource DangerGhostButton}"
                                                Click="ClearHistory_Click"/>
                                        <Button Content="打开数据目录" Width="140"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="8,0,0,0"
                                                Click="OpenDataDir_Click"/>
                                        <Button Content="保存设置" Width="100"
                                                Style="{StaticResource PrimaryButton}"
                                                Margin="8,0,0,0"
                                                Click="SaveConfig_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </TabItem>

                        <!-- ── Service Status Tab ─────────────── -->
                        <TabItem Header="服务状态">
                            <Border Style="{StaticResource CardBorder}"
                                    Margin="0,12,0,0">
                                <StackPanel VerticalAlignment="Top">
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse x:Name="ServiceDot" Width="10" Height="10"
                                                 Fill="{DynamicResource MutedForegroundBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock x:Name="LblServiceStatus"
                                                   Grid.Column="1"
                                                   Text="Python 服务: 检测中..."
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   FontSize="14" VerticalAlignment="Center"/>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Margin="0,24,0,4">
                                        <Button Content="重启服务" Width="120"
                                                Style="{StaticResource PrimaryButton}"
                                                Click="RestartService_Click"/>
                                        <Button Content="刷新状态" Width="120"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="8,0,0,0"
                                                Click="RefreshService_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
