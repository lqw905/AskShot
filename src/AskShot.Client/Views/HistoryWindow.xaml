<Window x:Class="AskShot.Client.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AskShot 历史记录"
        Height="560" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="{DynamicResource RadiusLg}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.12" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Title Bar ──────────────────────────────────── -->
            <Grid Grid.Row="0" Margin="8,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="历史记录"
                           FontFamily="{DynamicResource SerifFont}"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource HeavyForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnMinimize" Content="—"
                            Style="{StaticResource GhostButton}"
                            Width="36" Height="28" FontSize="16"
                            Click="Minimize_Click"/>
                    <Button x:Name="BtnClose" Content="×"
                            Style="{StaticResource GhostButton}"
                            Width="36" Height="28" FontSize="16"
                            Margin="4,0,0,0"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- ── Search Bar ────────────────────────────────── -->
            <Grid Grid.Row="1" Margin="14,8,14,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Height="40"
                         VerticalContentAlignment="Center"
                         FontSize="13"
                         KeyDown="SearchBox_KeyDown"/>
                <Button Grid.Column="1" Content="搜索" Width="80"
                        Style="{StaticResource SecondaryButton}"
                        Height="40" Margin="8,0,0,0"
                        Click="Search_Click"/>
                <Button Grid.Column="2" Content="最近" Width="80"
                        Style="{StaticResource SecondaryButton}"
                        Height="40" Margin="8,0,0,0"
                        Click="Recent_Click"/>
                <Button Grid.Column="3" Content="收藏/取消" Width="100"
                        Style="{StaticResource PrimaryButton}"
                        Height="40" Margin="8,0,0,0"
                        Click="ToggleFavorite_Click"/>
            </Grid>

            <!-- ── Content Split ─────────────────────────────── -->
            <Grid Grid.Row="2" Margin="14,0,14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ListBox x:Name="HistoryList" SelectionChanged="HistoryList_SelectionChanged"/>
                <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                              Background="Transparent"/>
                <Border Grid.Column="2"
                        Style="{StaticResource CardBorder}">
                    <TextBox x:Name="DetailsBox" IsReadOnly="True"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="{DynamicResource MonoFont}"
                             FontSize="12"
                             Background="Transparent"
                             BorderThickness="0"/>
                </Border>
            </Grid>

            <!-- ── Status Bar ─────────────────────────────────── -->
            <TextBlock x:Name="StatusText" Grid.Row="3"
                       Margin="14,8,14,10"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       FontSize="12" Text=""/>
        </Grid>
    </Border>
</Window>
