<Window x:Class="AskShot.Client.Views.ResultPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        Width="430" Height="320"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        KeyDown="Window_KeyDown">
    <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#D6D6D6" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.22"/>
        </Border.Effect>
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <TextBlock Text="解释" Foreground="#222222" FontSize="14"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="复制" Width="54" Height="28" Click="Copy_Click"
                            ToolTip="复制结果"/>
                    <Button x:Name="PinButton" Content="固定" Width="54" Height="28"
                            Margin="8,0,0,0" Click="Pin_Click" ToolTip="固定窗口"/>
                    <Button Content="关闭" Width="54" Height="28" Margin="8,0,0,0"
                            Click="Close_Click" ToolTip="关闭"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,12,0,8">
                <!-- Loading State -->
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Visibility="Collapsed">
                    <Grid Width="36" Height="36" Margin="0,0,0,10">
                        <Ellipse Width="36" Height="36" Stroke="#E8EAED"
                                 StrokeThickness="3" Fill="Transparent"/>
                        <Ellipse Width="36" Height="36" Stroke="#4285F4"
                                 StrokeThickness="3" Fill="Transparent"
                                 StrokeDashArray="28,84"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle"
                                                             From="0" To="360" Duration="0:0:1"
                                                             FillBehavior="HoldEnd"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                    <TextBlock Text="思考中..." Foreground="#5F6368" FontSize="14"
                               HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- Result State -->
                <TextBox x:Name="ResultText" Foreground="#202124" FontSize="14"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True" Background="Transparent" BorderThickness="0"
                         Padding="0" Text="" Visibility="Collapsed"/>
            </Grid>
            <Border Grid.Row="2" Background="#F1F3F4" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="QuestionBox" Foreground="#202124"
                             Background="Transparent" BorderThickness="0"
                             Padding="8,6" VerticalAlignment="Center"
                             KeyDown="QuestionBox_KeyDown"
                             Text="" ToolTip="继续追问"/>
                    <Button Grid.Column="1" Content="Ask" Width="48" Height="30"
                            Click="AskFollowUp_Click" ToolTip="追问"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
