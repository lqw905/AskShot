<Window x:Class="AskShot.Client.Views.ResultPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        Width="400" Height="300"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        KeyDown="Window_KeyDown">
    <Border Background="#F0222222" CornerRadius="10" BorderBrush="#444" BorderThickness="1">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="📌" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                        Width="30" Height="30" Click="Pin_Click" ToolTip="固定窗口"/>
                <Button Content="✕" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                        Width="30" Height="30" Click="Close_Click" ToolTip="关闭"/>
            </StackPanel>

            <!-- Result text (scrollable) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,5">
                <TextBlock x:Name="ResultText" Foreground="#EEEEEE" FontSize="14"
                           TextWrapping="Wrap" Text="分析中..."/>
            </ScrollViewer>

            <!-- Ask follow-up -->
            <Border Grid.Row="2" Background="#333" CornerRadius="6" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="QuestionBox" Foreground="White"
                             Background="Transparent" BorderThickness="0"
                             Padding="6,4" VerticalAlignment="Center"
                             KeyDown="QuestionBox_KeyDown"
                             Text=""/>
                    <Button Grid.Column="1" Content="→" Width="36" Height="28"
                            Click="AskFollowUp_Click" ToolTip="追问"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
