<Window x:Class="AskShot.Client.Views.ResultPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        Width="430" Height="320"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        KeyDown="Window_KeyDown">
    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="{DynamicResource RadiusLg}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.16" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Header ─────────────────────────────────────── -->
            <Grid>
                <TextBlock Text="解释"
                           FontFamily="{DynamicResource SerifFont}"
                           Foreground="{DynamicResource ForegroundBrush}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="复制" Width="48" Height="30"
                            Style="{StaticResource GhostButton}"
                            FontSize="12" MinWidth="0"
                            Click="Copy_Click" ToolTip="复制结果"/>
                    <Button x:Name="PinButton" Content="固定" Width="48" Height="30"
                            Style="{StaticResource GhostButton}"
                            FontSize="12" MinWidth="0"
                            Margin="4,0,0,0" Click="Pin_Click" ToolTip="固定窗口"/>
                    <Button Content="关闭" Width="48" Height="30"
                            Style="{StaticResource GhostButton}"
                            FontSize="12" MinWidth="0"
                            Margin="4,0,0,0" Click="Close_Click" ToolTip="关闭"/>
                </StackPanel>
            </Grid>

            <!-- ── Body ───────────────────────────────────────── -->
            <Grid Grid.Row="1" Margin="0,12,0,8">
                <!-- Loading State -->
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Visibility="Collapsed">
                    <Grid Width="36" Height="36" Margin="0,0,0,10">
                        <Ellipse Width="36" Height="36"
                                 Stroke="{DynamicResource MutedBrush}"
                                 StrokeThickness="3" Fill="Transparent"/>
                        <Ellipse Width="36" Height="36"
                                 Stroke="{DynamicResource BrandBrush}"
                                 StrokeThickness="3" Fill="Transparent"
                                 StrokeDashArray="28,84"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle"
                                                             From="0" To="360" Duration="0:0:1"
                                                             FillBehavior="HoldEnd"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                    <TextBlock Text="思考中..."
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               FontSize="14" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- Result State -->
                <TextBox x:Name="ResultText"
                         Foreground="{DynamicResource ForegroundBrush}"
                         FontSize="14"
                         FontFamily="{DynamicResource SansFont}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         MinHeight="0"
                         VerticalContentAlignment="Top"
                         Text=""
                         Visibility="Collapsed"/>
            </Grid>

            <!-- ── Follow-up Bar ─────────────────────────────── -->
            <Border Grid.Row="2"
                    Background="{DynamicResource PopoverBackgroundBrush}"
                    CornerRadius="{DynamicResource RadiusSm}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Padding="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <!-- Placeholder overlay -->
                        <TextBlock x:Name="PlaceholderText"
                                   Text="继续追问..."
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Padding="8,6"
                                   IsHitTestVisible="False"/>
                        <TextBox x:Name="QuestionBox"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="8,6"
                                 VerticalAlignment="Center"
                                 FontSize="13"
                                 KeyDown="QuestionBox_KeyDown"
                                 Text="" ToolTip="继续追问"/>
                    </Grid>

                    <Button Grid.Column="1" Content="Ask"
                            Style="{StaticResource PrimaryButton}"
                            Width="48" Height="34"
                            Margin="4,0,0,0"
                            FontSize="13" MinWidth="0"
                            Click="AskFollowUp_Click" ToolTip="追问"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
