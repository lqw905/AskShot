<Window x:Class="AskShot.Client.Views.RegionSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="Transparent"
        Cursor="None"
        KeyDown="Window_KeyDown">
    <Canvas x:Name="RootCanvas">
        <!-- Screenshot fills the entire virtual screen in DIP units. -->
        <Image x:Name="BackgroundImage"
               Stretch="Fill"
               Canvas.Left="0"
               Canvas.Top="0"
               Opacity="0.5" />

        <!-- ── Custom cursor: crosshair (4 segments + hollow center) ── -->
        <Line x:Name="CVTop" Stroke="#FFFFFF" StrokeThickness="0.5"
              Visibility="Collapsed" Canvas.ZIndex="10"/>
        <Line x:Name="CVBottom" Stroke="#FFFFFF" StrokeThickness="0.5"
              Visibility="Collapsed" Canvas.ZIndex="10"/>
        <Line x:Name="CHLeft" Stroke="#FFFFFF" StrokeThickness="0.5"
              Visibility="Collapsed" Canvas.ZIndex="10"/>
        <Line x:Name="CHRight" Stroke="#FFFFFF" StrokeThickness="0.5"
              Visibility="Collapsed" Canvas.ZIndex="10"/>
        <Ellipse x:Name="CursorDot" Stroke="#FFFFFF" StrokeThickness="1"
                 Width="6" Height="6" Fill="Transparent"
                 Visibility="Collapsed" Canvas.ZIndex="10"/>

        <!-- Selection outline -->
        <Border x:Name="SelectionBorder"
                BorderBrush="#FFFFFFFF"
                BorderThickness="0.5"
                Background="#22FFFFFF"
                Canvas.Left="0"
                Canvas.Top="0"
                Visibility="Collapsed" />
        <!-- Dimensions label -->
        <Border x:Name="SizeLabel"
                Background="#CC000000"
                CornerRadius="3"
                Padding="4,2"
                Canvas.Left="0"
                Canvas.Top="0"
                Visibility="Collapsed">
            <TextBlock x:Name="SizeText" Foreground="White" FontSize="14" />
        </Border>
    </Canvas>
</Window>
